#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

MODIFY_PROFILE=0
for ARG in "$@"; do
  case "$ARG" in
    --modify-profile)
      MODIFY_PROFILE=1
      ;;
    -h|--help)
      echo "Usage: ./setup [--modify-profile]"
      echo ""
      echo "Creates .venv, installs Walnut, and writes ~/.local/bin/walnut."
      echo "By default, shell profiles are not edited."
      echo "Use --modify-profile to add Walnut's command directory to your shell profile."
      exit 0
      ;;
    *)
      echo "error: unknown option: $ARG"
      echo "Usage: ./setup [--modify-profile]"
      exit 2
      ;;
  esac
done

REQUESTED_PYTHON="${PYTHON:-}"
if [[ -n "$REQUESTED_PYTHON" ]]; then
  PYTHON_CANDIDATES=("$REQUESTED_PYTHON")
else
  PYTHON_CANDIDATES=(python3.14 python3.13 python3.12 python3.11 python3.10 python3.9 python3)
fi

PYTHON_BIN=""
PYTHON_ERRORS=()
for CANDIDATE in "${PYTHON_CANDIDATES[@]}"; do
  if ! command -v "$CANDIDATE" >/dev/null 2>&1; then
    PYTHON_ERRORS+=("$CANDIDATE: not found")
    continue
  fi

  if ! VERSION_OUTPUT="$("$CANDIDATE" - <<'PY' 2>&1
import sys
try:
    from xml.parsers import expat  # catches broken Python/expat installs before venv creation
except Exception as exc:
    raise SystemExit(f"stdlib xml.parsers.expat is broken: {exc}")
if sys.version_info < (3, 9):
    raise SystemExit("Python 3.9+ required")
print(f"{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}")
PY
)"; then
    PYTHON_ERRORS+=("$CANDIDATE: $VERSION_OUTPUT")
    continue
  fi

  if ! "$CANDIDATE" -m venv --help >/dev/null 2>&1; then
    PYTHON_ERRORS+=("$CANDIDATE: venv is unavailable or broken")
    continue
  fi

  PYTHON_BIN="$CANDIDATE"
  PYTHON_VERSION="$VERSION_OUTPUT"
  break
done

if [[ -z "$PYTHON_BIN" ]]; then
  echo "error: could not find a working Python 3.9+ with venv support"
  printf '  - %s\n' "${PYTHON_ERRORS[@]}"
  echo ""
  echo "Try installing a stable Python, then rerun with:"
  echo "  PYTHON=python3.13 ./setup"
  exit 1
fi

echo "Using $PYTHON_BIN ($PYTHON_VERSION)"

VENV_DIR="${WALNUT_VENV:-"$ROOT/.venv"}"
if [[ ! -x "$VENV_DIR/bin/python" ]]; then
  echo "Creating virtual environment at $VENV_DIR..."
  "$PYTHON_BIN" -m venv "$VENV_DIR"
fi

VENV_PYTHON="$VENV_DIR/bin/python"
if ! "$VENV_PYTHON" -m pip install --help >/dev/null 2>&1; then
  echo "error: pip inside $VENV_DIR is unavailable or broken"
  echo "Delete $VENV_DIR and rerun ./setup, or rerun with PYTHON=/path/to/a/working/python."
  exit 1
fi

echo "Installing Walnut in editable mode inside .venv with terminal UI support..."
"$VENV_PYTHON" -m pip install -e .

USER_BIN="${WALNUT_BIN_DIR:-"$HOME/.local/bin"}"
mkdir -p "$USER_BIN"
WRAPPER="$USER_BIN/walnut"
cat > "$WRAPPER" <<EOF
#!/usr/bin/env bash
exec "$VENV_PYTHON" -m walnut.cli "\$@"
EOF
chmod +x "$WRAPPER"

export PATH="$USER_BIN:$PATH"

WALNUT_CMD=("$WRAPPER")
PATH_LINE="export PATH=\"$USER_BIN:\$PATH\""

if [[ "$MODIFY_PROFILE" == "1" ]]; then
  SHELL_NAME="$(basename "${SHELL:-}")"
  case "$SHELL_NAME" in
    zsh) PROFILE="$HOME/.zshrc" ;;
    bash) PROFILE="$HOME/.bashrc" ;;
    *) PROFILE="$HOME/.profile" ;;
  esac

  if ! grep -Fx "$PATH_LINE" "$PROFILE" >/dev/null 2>&1; then
    {
      echo ""
      echo "# Walnut CLI"
      echo "$PATH_LINE"
    } >> "$PROFILE"
    echo "Added Walnut's command directory to $PROFILE"
    echo "Open a new terminal, or run: source $PROFILE"
  fi
else
  echo "Shell profile unchanged."
  echo "To make walnut available in new terminals, add this line to your shell profile:"
  echo "  $PATH_LINE"
fi

echo ""
echo "Checking Walnut..."
"${WALNUT_CMD[@]}" doctor
"${WALNUT_CMD[@]}" verify --all

echo ""
echo "Ready."
echo ""
echo "Try:"
echo "  walnut        # interactive TUI"
echo "  walnut home   # static dashboard"
echo "  walnut topics"
echo "  walnut list arrays-and-hashing"
echo "  walnut show 3"
echo "  walnut pick 3"
echo "  walnut test 3 --perf"
echo ""
echo "Docs:"
echo "  docs/QUICKSTART.md"
echo "  docs/REPO_GUIDE.md"
